generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  decks      Deck[]
  reviewLogs ReviewLog[]

  @@map("users")
}

model Deck {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcards Flashcard[]

  @@index([userId])
  @@map("decks")
}

model Flashcard {
  id                String    @id @default(cuid())
  deckId            String    @map("deck_id")
  frontContent      String    @db.Text @map("front_content")
  backContent       String    @db.Text @map("back_content")
  difficulty        String    @default("normal")
  intervalDays      Float     @default(1) @map("interval_days")
  easeFactor        Float     @default(2.5) @map("ease_factor")
  repetitions       Int       @default(0)
  nextReviewAt      DateTime  @default(now()) @map("next_review_at")
  frontAudioUrl          String?   @map("front_audio_url")
  frontAudioPath         String?   @map("front_audio_path")
  frontAudioSize         Int?      @map("front_audio_size")
  frontAudioName         String?   @map("front_audio_name")
  frontAudioSource       String?   @map("front_audio_source")
  frontAudioProvider     String?   @map("front_audio_provider")
  frontAudioLanguage     String?   @map("front_audio_language")
  frontAudioVoice        String?   @map("front_audio_voice")
  frontAudioTextHash     String?   @map("front_audio_text_hash")
  frontAudioGeneratedAt  DateTime? @map("front_audio_generated_at")
  backAudioUrl           String?   @map("back_audio_url")
  backAudioPath          String?   @map("back_audio_path")
  backAudioSize          Int?      @map("back_audio_size")
  backAudioName          String?   @map("back_audio_name")
  backAudioSource        String?   @map("back_audio_source")
  backAudioProvider      String?   @map("back_audio_provider")
  backAudioLanguage      String?   @map("back_audio_language")
  backAudioVoice         String?   @map("back_audio_voice")
  backAudioTextHash      String?   @map("back_audio_text_hash")
  backAudioGeneratedAt   DateTime? @map("back_audio_generated_at")
  audioUpdatedAt         DateTime? @map("audio_updated_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  deck       Deck        @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviewLogs ReviewLog[]

  @@index([deckId])
  @@index([nextReviewAt])
  @@map("flashcards")
}

model ReviewLog {
  id                   String   @id @default(cuid())
  flashcardId          String   @map("flashcard_id")
  userId               String   @map("user_id")
  rating               String
  reviewedAt           DateTime @default(now()) @map("reviewed_at")
  previousIntervalDays Float    @map("previous_interval_days")
  newIntervalDays      Float    @map("new_interval_days")
  previousEaseFactor   Float    @map("previous_ease_factor")
  newEaseFactor        Float    @map("new_ease_factor")

  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([flashcardId])
  @@index([userId])
  @@index([reviewedAt])
  @@map("review_logs")
}
