# =============================================
# PostgreSQL
# =============================================
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=n8n_db

# =============================================
# n8n
# =============================================

# Chave de criptografia — gere uma chave aleatória forte
# Exemplo: openssl rand -hex 32
N8N_ENCRYPTION_KEY=troque_por_uma_chave_de_32_chars_ou_mais

# Porta de acesso local
N8N_PORT=5678

# Host e protocolo (use domínio real se estiver em produção)
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# Timezone
GENERIC_TIMEZONE=America/Sao_Paulo

# Modo de execução: regular | queue
EXECUTIONS_MODE=regular

# =============================================
# Autenticação básica (opcional)
# =============================================
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=troque_esta_senha
