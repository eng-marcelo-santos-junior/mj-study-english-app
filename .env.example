# Database — Supabase Pooler (runtime)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-sa-east-1.pooler.supabase.com:6543/postgres"

# Database — Supabase Direct (migrations only)
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Auth
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="your-super-secret-key-change-in-production"
AUTH_URL="http://localhost:3000"

# Supabase Storage (for audio files)
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-from-supabase-dashboard"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-from-supabase-dashboard"
SUPABASE_AUDIO_BUCKET="flashcard-audios"

# TTS service (optional — enables Edge TTS with voice selection)
# Run: cd services/tts-service && pip install -r requirements.txt && uvicorn app.main:app --port 5001 --reload
TTS_SERVER_URL="http://localhost:5001"

# Shared secret between the web app and the TTS service.
# Must match TTS_INTERNAL_API_KEY in services/tts-service/.env
# Leave empty to disable authentication (development only).
TTS_INTERNAL_API_KEY=""
